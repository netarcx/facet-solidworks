{
  "$schema": "./catalog.schema.json",
  "meta": {
    "version": 1,
    "device": "streamdeck_mk2",
    "grid": { "cols": 5, "rows": 3, "slots": 15 },
    "notes": "Single source of truth: layout -> slot(0..14, row-major) -> binding. Slot 0 is always Home (top-left); slot 14 is always More (bottom-right). swCommand names are validated against the swCommands_e enum extracted from the installed SolidWorks interop (SOLIDWORKS 2025)."
  },
  "layouts": {
    "none": {
      "title": "Welcome",
      "slots": [
        { "kind": "home", "label": "Facet" },
        { "kind": "command", "label": "New Part", "swCommand": "facet:newPart", "icon": "new-part" },
        { "kind": "command", "label": "New Assembly", "swCommand": "facet:newAssembly", "icon": "new-assembly" },
        { "kind": "command", "label": "New Drawing", "swCommand": "facet:newDrawing", "icon": "new-drawing" },
        { "kind": "command", "label": "Open", "swCommand": "swCommands_Open", "icon": "open" },
        { "kind": "empty" }, { "kind": "empty" }, { "kind": "info", "label": "Open a document\nto begin" }, { "kind": "empty" }, { "kind": "empty" },
        { "kind": "empty" }, { "kind": "empty" }, { "kind": "empty" }, { "kind": "empty" },
        { "kind": "empty" }
      ]
    },

    "part": {
      "title": "Part",
      "slots": [
